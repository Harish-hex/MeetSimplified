# Synthetix-4.0 Configuration
# Copy this file to .env and fill in your values.

OPENAI_API_KEY=sk-your-key-here
MODEL_NAME=gpt-4o-mini

# Anti-hallucination: minimum confidence (0–100) before failsafe triggers
CONFIDENCE_THRESHOLD=40

# Set to "false" to skip the verification pass (saves API cost during dev)
ENABLE_VERIFICATION_PASS=true
